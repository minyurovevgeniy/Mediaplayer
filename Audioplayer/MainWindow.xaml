<Window x:Class="Audioplayer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Audioplayer"
        mc:Ignorable="d"
        Title="Аудиоплеер" Height="500" Width="800">
    <Grid PreviewDragOver="Grid_PreviewDragOver">
        <Grid.RowDefinitions>
            <RowDefinition Height="87*"></RowDefinition>
            <RowDefinition Height="20"></RowDefinition>
            <RowDefinition Height="87*"></RowDefinition>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Button Content="Открыть" x:Name="chooseFile" Grid.Column="0" Grid.Row="0" Click="chooseFile_Click" Margin="10,272,10,10" />
        <TextBlock Grid.Column="1" Grid.Row="0" x:Name="headerBlock" TextWrapping="WrapWithOverflow" Margin="40,0,40,0" />

        <Slider x:Name="positionSlider" Grid.Row="1" Grid.ColumnSpan="3" Value="0" Minimum="0" Maximum="100" SelectionStart="0" Height="30" 
        IsSelectionRangeEnabled="True" ValueChanged="slider_ValueChanged" Margin="20,0,20,0"
                Thumb.DragStarted="PositionSlider_DragStarted"
                Thumb.DragCompleted="PositionSlider_DragCompleted"/>
        
        <ListBox x:Name="audioList" Grid.Column="2" Grid.Row="0" SelectionChanged="audioList_SelectionChanged" Panel.ZIndex="-1" IsManipulationEnabled="True" ScrollViewer.CanContentScroll="True" PreviewDragOver="audioList_PreviewDragOver" PreviewDrop="audioList_PreviewDrop" Drop="audioList_Drop" AllowDrop="True">
            <ListBox.ContextMenu>
                <ContextMenu>
                    <MenuItem x:Name="delete" Header="Удалить" Click="Delete" IsManipulationEnabled="True" />
                </ContextMenu>
            </ListBox.ContextMenu>
        </ListBox>

        <Button Grid.Column="0" Grid.Row="3" Content="Воспроизвести" Click="Play_Click" Margin="10,10,10,10" />
        <Button Grid.Column="1" Grid.Row="3" Content="Пауза" Click="Pause_Click" Margin="10,10,10,10"/>
        <Button Content="Стоп" Grid.Column="2" Grid.Row="3" Click="Stop_Click" Margin="10,10,10,10" />
        <Menu Height="25" VerticalAlignment="Top">
            <MenuItem Header="Файл">
                <MenuItem Header="Открыть" Click="chooseFile_Click"/>
                <MenuItem Header="Закрыть"/>
            </MenuItem>
            <MenuItem Header="Плейлист">
                <MenuItem Header="Открыть" Click="OpenPlaylistMenuItem_Click"/>
                <MenuItem Header="Сохранить" Click="SavePlaylistMenuItem_Click"/>
                <MenuItem Header="Закрыть"/>
            </MenuItem>
        </Menu>

    </Grid>
</Window>
